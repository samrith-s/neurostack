# Common VHS settings — source this mentally, not literally
# (VHS doesn't support includes, so copy these settings into each tape)
#
# Set Shell "bash"
# Set FontSize 16
# Set Width 1200
# Set Height 700
# Set Padding 20
# Set TypingSpeed 60ms
# Set Theme "Catppuccin Mocha"
# Set WindowBar Colorful
# Set WindowBarSize 40
# Env NEUROSTACK_VAULT_ROOT "/tmp/neurostack-demo-vhs/vault"
# Env NEUROSTACK_DB_DIR "/tmp/neurostack-demo-vhs/db"
